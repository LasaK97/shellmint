{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "base": "#1e1e2e",
    "blue": "#89b4fa",
    "crust": "#11111b",
    "flamingo": "#f2cdcd",
    "green": "#a6e3a1",
    "lavender": "#b4befe",
    "mantle": "#181825",
    "maroon": "#eba0ac",
    "mauve": "#cba6f7",
    "overlay0": "#6c7086",
    "peach": "#fab387",
    "pink": "#f5c2e7",
    "red": "#f38ba8",
    "rosewater": "#f5e0dc",
    "sapphire": "#74c7ec",
    "sky": "#89dceb",
    "subtext0": "#a6adc8",
    "subtext1": "#bac2de",
    "surface0": "#313244",
    "surface1": "#45475a",
    "surface2": "#585b70",
    "teal": "#94e2d5",
    "text": "#cdd6f4",
    "yellow": "#f9e2af"
  },
  "transient_prompt": {
    "template": "\ue285 ",
    "foreground": "p:rosewater",
    "background": "transparent"
  },
  "upgrade": {
    "source": "cdn",
    "interval": "168h",
    "auto": false,
    "notice": false
  },
  "console_title_template": "{{ .Folder }}",
  "terminal_background": "#000000",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "leading_diamond": "<p:blue> \ue200 </>",
          "template": "{{ .UserName }} <p:text>on</>",
          "foreground": "p:rosewater",
          "type": "session",
          "style": "diamond"
        },
        {
          "options": {
            "time_format": "Monday <p:text>at</> 3:04 PM"
          },
          "template": " {{ .CurrentDate | date .Format }} ",
          "foreground": "p:mauve",
          "type": "time",
          "style": "diamond"
        },
        {
          "options": {
            "branch_icon": "\ue725 ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "p:pink",
          "type": "git",
          "style": "diamond",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:peach{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:red{{ end }}",
            "{{ if gt .Ahead 0 }}p:sky{{ end }}",
            "{{ if gt .Behind 0 }}p:flamingo{{ end }}"
          ]
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "options": {
            "style": "dallas",
            "threshold": 3000
          },
          "template": " {{ .FormattedMs }}s <p:text>\ue601</>",
          "foreground": "p:yellow",
          "type": "executiontime",
          "style": "diamond"
        },
        {
          "template": " \ue235 {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }} ",
          "foreground": "p:green",
          "type": "python",
          "style": "diamond"
        },
        {
          "template": " \ue718 {{ .Full }} ",
          "foreground": "p:peach",
          "type": "node",
          "style": "diamond"
        },
        {
          "template": " \ue627 {{ .Full }} ",
          "foreground": "p:sky",
          "type": "go",
          "style": "diamond"
        },
        {
          "template": " \ue7a8 {{ .Full }} ",
          "foreground": "p:maroon",
          "type": "rust",
          "style": "diamond"
        },
        {
          "options": {
            "root_icon": "\uf292 "
          },
          "template": " \uf0e7 ",
          "foreground": "p:red",
          "type": "root",
          "style": "diamond"
        },
        {
          "template": " <p:text>MEM:</> {{ round .PhysicalPercentUsed .Precision }}% ({{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB)",
          "foreground": "p:teal",
          "type": "sysinfo",
          "style": "diamond"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "folder_icon": "\uf07b",
            "folder_separator_icon": " \uebcb ",
            "home_icon": "home",
            "style": "agnoster_full"
          },
          "leading_diamond": "<p:sapphire> \ue285 </><p:pink>{</>",
          "trailing_diamond": "<p:pink>}</>",
          "template": " \ue5ff {{ .Path }} ",
          "foreground": "p:pink",
          "type": "path",
          "style": "diamond"
        },
        {
          "options": {
            "always_enabled": true
          },
          "template": " \ue286 ",
          "foreground": "p:green",
          "type": "status",
          "style": "plain",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ]
        }
      ],
      "newline": true
    }
  ],
  "version": 4
}
